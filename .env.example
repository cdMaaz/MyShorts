# Server
MAX_CONCURRENT_JOBS=3
JOB_TTL_SECONDS=7200
UPLOAD_DIR=uploads
OUTPUT_DIR=output

# Optional: YouTube bot-detection bypass
# Paste the contents of a Netscape-format cookies.txt exported from your browser
# YOUTUBE_COOKIES=

# Gemini key can also be set server-side (overrides per-request key)
# GEMINI_API_KEY=
